{
  "$schema": "https://unpkg.com/@hey-api/openapi-ts@0.94.5/dist/json-schema.json",
  "input": "http://localhost:5000/openapi.json",
  "output": "src/generated",
  "client": "axios",
  "useOptions": true,
  "services": {
    "include": "^.*",
    "asClass": true
  },
  "types": {
    "include": "^.*"
  },
  "enums": false,
  "exportCore": true
}
